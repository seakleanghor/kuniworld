<!DOCTYPE html>
<html>
<head>
    <title><%= university.name %> | KUni World</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

<nav>
    <a href="/" class="logo">
        <img src="/images/logo.png" alt="KUni World">
    </a>

    <button class="menu-toggle" onclick="toggleMenu()" id="menuBtn">
        ☰
    </button>

    <div class="nav-links" id="navLinks">
        <a href="/">Home</a>
        <a href="/universities">Universities</a>
        <a href="/consultant">AI Consultant</a>
        <a href="/timeline">Timeline</a>
        <a href="/comparison">Comparison</a>
        <a href="/scholarships">Scholarships</a>
        <a href="/calculator">Cost Calculator</a>
    </div>
</nav>

<section>

    <div class="hero">
        <h1><i class="fa-solid fa-graduation-cap"></i> <%= university.name %></h1>
        <p>Detailed University Information</p>
    </div>

    <div class="card">

        <h2>University Profile</h2>

        <p>
            <strong><i class="fa-solid fa-location-dot"></i>Location:</strong>
            <%= university.location %>
        </p>

        <p>
            <strong><i class="fa-solid fa-trophy"></i>Korea Ranking:</strong>
            <%= university.ranking %>
        </p>

        <p>
            <strong><i class="fa-solid fa-building-columns"></i>Type:</strong>
            <%= university.type %>
        </p>

    </div>

    <div class="card">

        <h2>Academic Information</h2>

        <p>
            <strong><i class="fa-solid fa-layer-group"></i>Major:</strong>
            <%= university.major %>
        </p>

        <p>
            <strong><i class="fa-solid fa-note-sticky"></i>TOPIK Requirement:</strong>
            <%= university.topik %>
        </p>

        <p>
            <strong><i class="fa-solid fa-money-bill-wave"></i>Tuition:</strong>
            <%= university.tuition %>
        </p>

    </div>

    <div class="card">

        <h2>Student Support</h2>

        <p>
            <strong><i class="fa-solid fa-building-columns"></i>Dormitory:</strong>
            <%= university.dormitory %>
        </p>

        <p>
            <strong><i class="fa-solid fa-gift"></i>Scholarship:</strong>
            <%= university.scholarship %>
        </p>

    </div>

    <div class="card">

        <h2>Why Choose This University?</h2>

        <p>
            This university offers quality education,
            student support services, scholarship opportunities,
            and a diverse international student community.
        </p>

    </div>

    <a href="/universities">
        <button><strong></strong><i class="fa-solid fa-arrow-left"></i>Back to University List</button>
    </a>

</section>

<footer>
    <hr>
    <p>© 2026 KUni World. All Rights Reserved.</p>
    <p>Your Gateway to Korean Universities</p>
</footer>
    <script>

    function toggleMenu() {

        const navLinks =
            document.getElementById("navLinks");

        const menuBtn =
            document.getElementById("menuBtn");

        navLinks.classList.toggle("show");

        if (navLinks.classList.contains("show")) {
            menuBtn.innerHTML = "✕";
        } else {
            menuBtn.innerHTML = "☰";
        }

    }

    </script>
</body>
</html>